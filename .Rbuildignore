^LICENSE\.md$
^\.github$
^_pkgdown\.yml$
^docs$
^pkgdown$
^downBallotPython$
^Developer_Resources$
^README\.md$
^data$
\.vscode
\.claude
\.claude/
\.Rhistory
\.DS_Store
^\.venv$

# Python cache / compiled files (never belong in source package)
(^|/)__pycache__($|/)
(^|/)\.pytest_cache($|/)
.*\.pyc$
.*\.pyo$

# Test output directories from inst/python
^inst/python/.*/.*_outputs?$
^inst/python/.*/__pycache__$

# Cached HTML / network logs from inspect scripts
^inst/python/.*\.html$
^inst/python/.*_network_log\.json$

# Any scratch output directories
_outputs?$
output_$
